#!/usr/bin/env python
import sys
from argparse import ArgumentParser
from shutil import which
from subprocess import *


def get_tags(url):
    out = (
        check_output(
            [
                which("git"),
                "-c",
                "versionsort.suffix=-",
                "ls-remote",
                "--tags",
                "--refs",
                "--sort=v:refname",
                url,
            ]
        )
        .decode("utf8")
        .rstrip()
    )
    if not out:
        return []
    tags = [x.split("/")[-1] for x in out.split("\n")]
    return tags


def clone_tag(url, tag, dest=None):
    args = [which("git"), "clone", "--branch", tag, "--depth", "1", url]
    if dest is not None:
        args.append(dest)
    check_call(args)


def fzf(choices):
    out = run(
        [which("fzf"), "--tac"],
        check=True,
        capture_output=True,
        input="\n".join(choices).encode("utf8"),
    )
    return out.stdout.decode("utf8").rstrip()


if __name__ == "__main__":
    parser = ArgumentParser(
        "clone-last",
        description="""Try to find the most recent tag of a Git repository.
        Prompt the user to perform a shallow clone of the detected tag or use
        fzf to select some other tag.""",
    )
    parser.add_argument("url", metavar="URL", help="Git repository")
    parser.add_argument(
        "dest", nargs="?", metavar="DEST", help="destination folder"
    )
    args = parser.parse_args()

    bad = False
    for dep in ["fzf", "git"]:
        if not which(dep):
            print(f"Required executable not found: '{dep}'")
            bad = True
    if bad:
        exit(1)

    try:
        tags = get_tags(args.url)
        if not tags:
            print(f"Could not find any tags for '{args.url}'")
            exit(1)
        tag = tags[-1]

        print(f"Found tag '{tag}'")
        while True:
            choice = input("Proceed? (y/n/q): ")
            match choice.lower():
                case "y":
                    break
                case "n":
                    exit(0)
                case "q":
                    try:
                        tag = fzf(tags)
                    except CalledProcessError as err:
                        print("No tag selected")
                        exit(1)
                    break

        print(f"Continuing with tag '{tag}'")
        clone_tag(args.url, tag, args.dest)

    except CalledProcessError as err:
        print(err, file=sys.stderr)
        exit(1)
